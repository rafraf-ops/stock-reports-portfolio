# ─────────────────────────────────────────────────────────────────────────────
# Financial Analyzer – Environment Variables
# Copy to .env and fill in your keys
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# In production set to your domain, e.g. https://myapp.example.com
CORS_ORIGIN=*

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./database.db

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ─────────────────────────────────────────────────────────────────────────────
# DATA PROVIDERS  (all optional – app works with just Yahoo Finance for free)
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude AI (Anthropic) – for AI company analysis ──────────────────────────
# Get from: https://console.anthropic.com/
CLAUDE_API_KEY=

# ── Yahoo Finance ─────────────────────────────────────────────────────────────
# FREE – no key needed. Supports: US stocks, TASE (.TA in ILS), crypto, FX rates.
# Nothing to configure – used automatically.

# ── CoinGecko – cryptocurrency prices ─────────────────────────────────────────
# FREE without key (300 calls/min). Optional key for higher limits.
# Get from: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# ── Financial Modeling Prep (FMP) – company profiles / market cap ─────────────
# Free tier: 250 calls/day. Get from: https://site.financialmodelingprep.com/
FMP_API_KEY=

# ── Alpha Vantage – US stock prices (fallback) + fundamentals ────────────────
# Free tier: 25 calls/day. Get from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# ── Finnhub – stock prices (fallback) + NEWS & SENTIMENT ─────────────────────
# Free tier: 60 calls/min. Get from: https://finnhub.io/register
# Enables: /api/stock-price/:symbol/news endpoint
FINNHUB_API_KEY=

# ── Twelve Data – stock prices (last fallback) ────────────────────────────────
# Free tier: 800 calls/day. Get from: https://twelvedata.com/
TWELVE_DATA_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# PROVIDER PRIORITY (automatic, no config needed):
#
#  US stocks:    Yahoo Finance → Finnhub → Alpha Vantage → Twelve Data → mock
#  TASE stocks:  Yahoo Finance (native ILS prices) → mock
#  Crypto:       CoinGecko → Yahoo Finance (BTC-USD) → mock
#  Exchange rate: Yahoo Finance (USDILS=X) → Bank of Israel API → 3.7 fallback
#  News:         Finnhub → Alpha Vantage → (none)
#  Historical:   Yahoo Finance → Alpha Vantage → CoinGecko (crypto) → (empty)
# ─────────────────────────────────────────────────────────────────────────────
